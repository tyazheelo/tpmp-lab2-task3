#include <stdio.h>
#include <string.h>
#include "worker.h"

// Функция ввода данных о работниках
void input_workers(struct WORKER2 workers[], int count) {
    for (int i = 0; i < count; i++) {
        printf("Введите данные работника #%d:\n", i + 1);
        printf("Код: ");
        scanf("%d", &workers[i].code);
        printf("Фамилия: ");
        scanf("%s", workers[i].lastname);
        printf("Должность: ");
        scanf("%s", workers[i].position);
        printf("Пол (M/F): ");
        scanf(" %c", &workers[i].sex);
        printf("Дата подписания контракта (год месяц день): ");
        scanf("%d %d %d", 
              &workers[i].contract_date.year,
              &workers[i].contract_date.month,
              &workers[i].contract_date.day);
        printf("Срок контракта (месяцев): ");
        scanf("%d", &workers[i].contract_term);
        printf("Оклад: ");
        scanf("%f", &workers[i].salary);
        printf("\n");
    }
}

